---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllVideos, CATEGORIES, formatDate, youtubeThumbnail } from '../../lib/content';
const videos = getAllVideos();
const liveVideos = videos.filter((v: any) => !v.comingSoon);
---
<BaseLayout title="Videos" description="Video content from Calgary CX on CCaaS, CX AI, AI Agents, and contact center operations.">

  <div class="page-hero">
    <div class="container">
      <div class="section-eyebrow">Watch</div>
      <h1>Videos</h1>
      <p class="lead" style="max-width:520px;">Video commentary and analysis on enterprise CX topics from JP Sivasubramaniam.</p>
    </div>
  </div>

  <section>
    <div class="container">
      {liveVideos.length === 0 ? (
        <div style="max-width:640px;margin:0 auto;">

          <!-- Coming soon card -->
          <div style="background:var(--ink);border-radius:var(--r-lg);overflow:hidden;margin-bottom:3rem;">
            <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#1c1f28 0%,#2e3340 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden;">
              <!-- Background glow -->
              <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(192,57,43,0.15) 0%,transparent 70%);"></div>
              <!-- Play button -->
              <div style="width:72px;height:72px;border-radius:50%;background:rgba(192,57,43,0.9);display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;position:relative;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
              </div>
              <p style="color:rgba(255,255,255,0.9);font-family:var(--ff-display);font-size:1.35rem;font-weight:600;margin-bottom:0.5rem;position:relative;text-align:center;padding:0 2rem;">Video Content Coming Soon</p>
              <p style="color:rgba(255,255,255,0.4);font-size:0.85rem;position:relative;text-align:center;padding:0 2rem;">Practitioner perspectives on CCaaS, Voice AI, and CX strategy</p>
            </div>
            <div style="padding:1.5rem 2rem;">
              <span class="category-pill cat-ccaas" style="margin-bottom:1rem;display:inline-flex;">CCaaS</span>
              <h3 style="font-family:var(--ff-display);color:white;font-size:1.2rem;margin-bottom:0.5rem;">JP Sivasubramaniam brings Calgary CX to video</h3>
              <p style="color:rgba(255,255,255,0.45);font-size:0.9rem;line-height:1.6;">CCaaS migrations, Voice AI deployments, WFO strategy, and contact center operations. Subscribe to get notified when the first video drops.</p>
              <div style="margin-top:1.5rem;">
                <a href="/newsletter" class="btn btn-primary">Get Notified</a>
              </div>
            </div>
          </div>

          <!-- Articles CTA -->
          <div style="text-align:center;padding:2rem 0;">
            <p style="color:var(--text-3);margin-bottom:1.5rem;">In the meantime, explore the latest articles.</p>
            <a href="/articles" class="btn btn-outline">Browse Articles</a>
          </div>

        </div>
      ) : (
        <div class="video-grid">
          {liveVideos.map((video: any) => (
            <a href={`/videos/${video.slug}`} class="video-card">
              <div class="video-thumb">
                <img src={youtubeThumbnail(video.youtubeId)} alt={video.title} loading="lazy" />
                <div class="video-play-btn">
                  <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="video-body">
                <div class="video-meta">
                  <span class={`category-pill cat-${video.category}`}>{video.categoryLabel}</span>
                  {video.duration && <span class="video-duration">{video.duration}</span>}
                </div>
                <div class="video-title">{video.title}</div>
                <p class="video-desc">{video.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</BaseLayout>
