---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllArticles, getArticleBySlug, formatDate } from '../../lib/content';
import { marked } from 'marked';

export async function getStaticPaths() {
  return getAllArticles().map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getArticleBySlug(slug!);
if (!article) return Astro.redirect('/articles');

const htmlContent = marked.parse(article.content);
const related = getAllArticles().filter(a => a.slug !== slug && a.category === article.category).slice(0, 3);


const heroImage = article.heroImage ?? null;
const heroImageAlt = article.heroImageAlt ?? article.title;

const siteUrl = 'https://calgarycx.ca';
const articleUrl = `${siteUrl}/articles/${slug}`;
const linkedInShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(articleUrl)}`;
const xShare = `https://twitter.com/intent/tweet?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(article.title)}`;
---
<BaseLayout title={article.title} description={article.description} article={true}>

  <div class="article-hero">
    <div class="article-hero-inner">
      <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;margin-bottom:0.5rem;">
        <a href={`/categories/${article.category}`} class={`category-pill cat-${article.category}`}>{article.categoryLabel}</a>
        <span style="font-size:0.78rem;color:rgba(255,255,255,0.35);font-family:var(--ff-mono);">{article.readTime}</span>
      </div>
      <h1>{article.title}</h1>
      <p class="lead">{article.description}</p>
      <div class="article-byline">
        <div class="byline-avatar">JP</div>
        <div class="byline-info">
          <span class="byline-name">{article.author}</span>
          <span class="byline-meta">{formatDate(article.pubDate)}</span>
        </div>
      </div>
    </div>
  </div>

  {heroImage && (
    <div style="max-width:720px;margin:0 auto;padding:2.5rem 1.5rem 0;">
      <img
        src={heroImage}
        alt={heroImageAlt}
        style="width:100%;border-radius:10px;display:block;box-shadow:0 4px 24px rgba(0,0,0,0.12);"
        loading="eager"
      />
    </div>
  )}

  <section>
    <div class="container--narrow">
      <div class="prose" set:html={htmlContent} />

      <hr class="rule" style="margin:3rem 0;" />

      <!-- Share buttons -->
      <div style="margin-bottom:2.5rem;">
        <p style="font-size:0.78rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-3);margin-bottom:1rem;">Share this article</p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a
            href={linkedInShare}
            target="_blank"
            rel="noopener noreferrer"
            style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.6rem 1.1rem;border-radius:999px;font-size:0.85rem;font-weight:600;background:#0a66c2;color:white;text-decoration:none;transition:opacity 0.2s;"
            onmouseover="this.style.opacity='0.85'"
            onmouseout="this.style.opacity='1'"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>

          <a
            href={xShare}
            target="_blank"
            rel="noopener noreferrer"
            style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.6rem 1.1rem;border-radius:999px;font-size:0.85rem;font-weight:600;background:#000;color:white;text-decoration:none;transition:opacity 0.2s;"
            onmouseover="this.style.opacity='0.75'"
            onmouseout="this.style.opacity='1'"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>

          <button
            id="copyLinkBtn"
            onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.textContent='Copied!';this.style.background='var(--red)';this.style.color='white';setTimeout(()=>{this.innerHTML='<svg width=14 height=14 viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\"/><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"/></svg> Copy link';this.style.background='';this.style.color='';},2000)})"
            style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.6rem 1.1rem;border-radius:999px;font-size:0.85rem;font-weight:600;background:transparent;color:var(--text-2);border:1.5px solid var(--mist-2);cursor:pointer;transition:all 0.2s;"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Copy link
          </button>
        </div>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <a href="/articles" class="btn btn-outline"><svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 16L0 8l8-8 1.4 1.4L3.8 7H16v2H3.8l5.6 5.6z"/></svg> All Articles</a>
        <a href={`/categories/${article.category}`} class={`category-pill cat-${article.category}`}>{article.categoryLabel}</a>
      </div>
    </div>
  </section>

  {related.length > 0 && (
    <section style="background:var(--mist);padding:4rem 0;">
      <div class="container">
        <div class="section-eyebrow">Keep Reading</div>
        <h2 style="margin-bottom:2rem;">More in {article.categoryLabel}</h2>
        <div class="article-grid">
          {related.map(rel => (
            <article class="article-card">
              <div class="card-body">
                <div class="card-meta"><span class="card-date">{formatDate(rel.pubDate)}</span></div>
                <h3 class="card-title">{rel.title}</h3>
                <p class="card-excerpt">{rel.description}</p>
              </div>
              <div class="card-footer">
                <a href={`/articles/${rel.slug}`} class="read-link">Read article <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0l8 8-8 8-1.4-1.4L12.2 9H0V7h12.2L6.6 1.4z"/></svg></a>
                <span class="read-time">{rel.readTime}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
