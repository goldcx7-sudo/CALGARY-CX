---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllArticles, CATEGORIES } from '../../lib/content';
const articles = getAllArticles();
---
<BaseLayout title="Categories" description="Browse Calgary CX articles by category.">
  <div class="page-hero">
    <div class="container">
      <div class="section-eyebrow">Browse</div>
      <h1>Categories</h1>
      <p class="lead">Find articles by topic across the enterprise CX landscape.</p>
    </div>
  </div>
  <section>
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
        {CATEGORIES.map(cat => {
          const count = articles.filter(a => a.category === cat.slug).length;
          return (
            <a href={`/categories/${cat.slug}`} style="display:block;text-decoration:none;">
              <div class="article-card" style="height:100%;cursor:pointer;">
                <div class="card-body">
                  <div style="margin-bottom:1rem;"><span class={`category-pill cat-${cat.slug}`}>{cat.label}</span></div>
                  <h3 class="card-title" style="font-size:1.25rem;margin-bottom:0.5rem;">{cat.label}</h3>
                  <p style="font-size:0.9rem;color:var(--text-3);line-height:1.6;margin:0;">{cat.description}</p>
                </div>
                <div class="card-footer">
                  <span class="read-link">{count} article{count !== 1 ? 's' : ''} <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0l8 8-8 8-1.4-1.4L12.2 9H0V7h12.2L6.6 1.4z"/></svg></span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
